# Sao chép file này thành .env (không commit .env nếu có thông tin nhạy cảm).
# URL endpoint Spring Boot trả về JSON đúng schema trong types/aiItinerary.ts
#
# Ví dụ Android emulator → máy dev: http://10.0.2.2:8081/api/v1/ai/itinerary
# Ví dụ thiết bị thật cùng Wi‑Fi: http://192.168.1.x:8081/api/v1/ai/itinerary
# Để trống hoặc không tạo .env → app dùng mock cục bộ (phù hợp demo báo cáo).

EXPO_PUBLIC_AI_ITINERARY_URL=
# Khóa SerpApi để chatbot lấy điểm tham quan, cafe, nhà hàng trực tiếp từ Google Maps/Local.
EXPO_PUBLIC_SERPAPI_KEY=
# Cấu hình LLM theo chuẩn OpenAI-compatible để bot sinh lịch trình từ ngữ cảnh đã truy xuất.
EXPO_PUBLIC_LLM_BASE_URL=
EXPO_PUBLIC_LLM_API_KEY=
EXPO_PUBLIC_LLM_MODEL=gpt-4o-mini
